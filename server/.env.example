# Database (Neon PostgreSQL)
# Pooled connection (for runtime queries)
DATABASE_URL="postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET="your-secret-key-here"

# Server
PORT=3000
